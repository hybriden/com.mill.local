{
  "id": "com.mill.local",
  "version": "1.0.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": ["local"],
  "name": {
    "en": "Mill Local"
  },
  "description": {
    "en": "Control Mill Gen3 heaters via local REST API"
  },
  "category": ["climate"],
  "permissions": [],
  "author": {
    "name": "hybriden"
  },
  "drivers": [
    {
      "id": "mill-gen3",
      "name": {
        "en": "Mill Gen3 Heater"
      },
      "class": "thermostat",
      "capabilities": [
        "onoff",
        "target_temperature",
        "measure_temperature"
      ],
      "capabilitiesOptions": {
        "target_temperature": {
          "min": 5,
          "max": 35,
          "step": 0.5
        }
      },
      "pair": [
        {
          "id": "discover",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ]
    }
  ]
}
